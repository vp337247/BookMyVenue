{
  "name": "book-my-venue-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:migrate": "knex migrate:latest --knexfile src/infrastructure/database/knexfile.ts",
    "db:rollback": "knex migrate:rollback --knexfile src/infrastructure/database/knexfile.ts",
    "db:seed": "knex seed:run --knexfile src/infrastructure/database/knexfile.ts",
    "db:seed:specific": "knex seed:run --knexfile src/infrastructure/database/knexfile.ts --specific",
    "cli": "ts-node src/infrastructure/cli/cli.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.10.4",
    "@nestjs/apollo": "^12.1.0",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.8",
    "@nestjs/graphql": "^12.1.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.3.8",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "graphql": "^16.8.1",
    "handlebars": "^4.7.9",
    "knex": "^3.1.1",
    "nest-commander": "^3.13.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^15.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
